    "notion",
    "mongodb",
    "rss",
    "linkedin",
    "twitter",
    "beehiiv"
  ],
  "homepage": "https://github.com/YOUR_ORG/YOUR_REPO#readme",
  "bugs": {
    "url": "https://github.com/YOUR_ORG/YOUR_REPO/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_ORG/YOUR_REPO.git"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
