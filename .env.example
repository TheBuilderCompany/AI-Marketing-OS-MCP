# ============================================================
# Marketing MCP Server – Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ----- Server -----
PORT=3000
NODE_ENV=production

# ----- MongoDB -----
# Local: mongodb://127.0.0.1:27017/marketing_mcp
# Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/marketing_mcp
MONGODB_URI=Your-MONGO-URL
# ----- X (Twitter) API v2 -----
# https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your-bearer-token-here
TWITTER_API_KEY=your-api-key-here
TWITTER_API_SECRET=your-api-secret-here
TWITTER_ACCESS_TOKEN=your-access-token-here
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret-here

# ----- LinkedIn API -----
# App dashboard: https://www.linkedin.com/developers/apps
#
# CLIENT ID & SECRET — found on your app's "Auth" tab.
# These are NOT the access token. They are used in the OAuth 2.0
# flow to *exchange* for an access token (a one-time setup step).
LINKEDIN_CLIENT_ID=your-client-id-here
LINKEDIN_CLIENT_SECRET=your-client-secret-here
#
# ACCESS TOKEN — obtained after completing the OAuth 2.0 flow:
#   1. Authorize via: https://www.linkedin.com/oauth/v2/authorization
#      Scopes needed: w_organization_social r_organization_social
#   2. Exchange the returned "code" for a token using your client credentials.
#      (See DEPLOYMENT.md or ask Claude to walk you through the steps.)
# ⚠️  Expires after 60 days — refresh before it does!
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_REFRESH_TOKEN=your-linkedin-refresh-token-here
#
# ORGANIZATION URN — your company page ID, e.g. urn:li:organization:12345
# Find it: go to your LinkedIn company page → the number in the URL is your ID.
LINKEDIN_ORGANIZATION_URN=urn:li:organization:your-org-id
#
# AUTHOR URN — your personal member ID, e.g. urn:li:person:abcdefg
# Find it by calling GET https://api.linkedin.com/v2/userinfo
LINKEDIN_AUTHOR_URN=urn:li:person:your-person-id

# ----- Beehiiv (Newsletter) API -----
# https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=your-beehiiv-api-key-here
BEEHIIV_PUBLICATION_ID=pub_your-publication-id-here

# ----- Notion API -----
# https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your-notion-api-key-here
NOTION_DATABASE_ID=your-notion-database-id-here

# ----- MCP Security -----
# Optional shared secret for restricting access to the MCP endpoint
MCP_AUTH_SECRET=change-me-to-a-strong-random-secret
